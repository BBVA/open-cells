{
  "name": "open-cells",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "license": "Apache-2.0",
  "author": "",
  "main": "index.js",
  "scripts": {
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
    "build": "wireit",
    "test": "wireit",
    "end-task": "changeset && git add --all",
    "create:preview": "cd ./packages/example && node ../create-app/src/create.js",
    "changeset": "changeset",
    "beta:on": "node scripts/preEnter.js beta",
    "beta:off": "node scripts/preExit.js",
    "rc:on": "node scripts/preEnter.js rc",
    "rc:off": "node scripts/preExit.js",
    "version": "npm run changeset version && npm run create-app:update",
    "create-app:update": "npm --prefix ./packages/create-app run update"
  },
  "keywords": [],
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.16.10",
    "@typescript-eslint/parser": "^8.8.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "camelcase": "^8.0.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.12.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-config-prettier": "^8.2.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.0.0",
    "prettier-plugin-jsdoc": "^1.0.0",
    "typescript": "^5.6.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wireit": "^0.14.1"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "./packages/core:build",
        "./packages/example/recipes-app:build",
        "./packages/element-controller:build",
        "./packages/page-controller:build"
      ]
    },
    "test": {
      "dependencies": [
        "./packages/core:test",
        "./packages/example/recipes-app:test"
      ]
    }
  },
  "workspaces": [
    "packages/*",
    "packages/example/*"
  ],
  "overrides": {
    "minimatch@3.x": "3.1.3",
    "minimatch@5.x": "5.1.9",
    "minimatch@10.x": "10.2.1",
    "tar": "^7.5.8"
  }
}
